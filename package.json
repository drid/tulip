  },
  "homepage": "https://github.com/storm-factory/tulip",
  "devDependencies": {
    "@electron-forge/cli": "^6.0.5",
    "@electron-forge/maker-dmg": "^7.6.0",
    "electron": "^29.4.6",
    "electron-builder": "^25.1.8",
    "tape": "^4.14.0"
  },
  "dependencies": {
